# Folio local dev config.
#
# Copy to .env to override defaults. .env is gitignored.
# Only the host port is configurable — the container always listens on 8000.

# Host port to expose the app on. Default 8000 (matches the README).
# Change this if 8000 conflicts with something else on your machine.
FOLIO_PORT=8000

# Server-wide timezone. Used to parse staff datetime-local input on
# document create and to display the publish time to recipients hitting
# a not-yet-available share link. Default America/Chicago.
#
# This is single-tz on purpose. Multi-tz (per-document or per-staff)
# is a deliberately punted upgrade path — see the backlog focus card
# referenced in .coda/designs/scheduled-publishing.md.
FOLIO_TZ=America/Chicago
